        "message": "=<div style=\"font-family:Arial,sans-serif;max-width:640px\">\n<h2 style=\"margin:0 0 4px\">Weekly Resourcing Forecast</h2>\n<p style=\"color:#666;margin:0 0 16px\">Run date: {{ $json.run_date }} &nbsp;|&nbsp; Severity: <strong>{{ $json.alert_severity }}</strong></p>\n<p style=\"font-size:15px\"><strong>{{ $json.headline }}</strong></p>\n<table style=\"border-collapse:collapse;margin:12px 0;font-size:14px\">\n<tr><td style=\"padding:4px 12px 4px 0\"><strong>Fill Rate</strong></td><td>{{ $json.fill_rate_pct }}% ({{ $json.filled_roles }}/{{ $json.total_roles }})</td></tr>\n<tr><td style=\"padding:4px 12px 4px 0\"><strong>Unfilled Roles</strong></td><td>{{ $json.unfilled_count }}</td></tr>\n<tr><td style=\"padding:4px 12px 4px 0\"><strong>Revenue at Risk</strong></td><td>${{ $json.revenue_at_risk }}</td></tr>\n<tr><td style=\"padding:4px 12px 4px 0\"><strong>Forecast Accuracy Delta</strong></td><td>{{ $json.forecast_accuracy_delta }}</td></tr>\n</table>\n<p>{{ $json.narrative }}</p>\n<h3 style=\"margin:16px 0 4px\">Key Risks</h3>\n<pre style=\"white-space:pre-wrap;font-family:Arial,sans-serif;font-size:14px\">{{ $json.key_risks_text }}</pre>\n<h3 style=\"margin:16px 0 4px\">Recommended Actions</h3>\n<pre style=\"white-space:pre-wrap;font-family:Arial,sans-serif;font-size:14px\">{{ $json.recommended_actions_text }}</pre>\n</div>",
