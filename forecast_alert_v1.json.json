    {
      "parameters": {
        "jsCode": "\nconst res = ($input.all()[0] || {}).json || {};\n\nlet text = '';\nif (res && Array.isArray(res.content)) {\n  text = res.content.map(c => (c && c.text) ? c.text : '').join('');\n} else if (typeof res.completion === 'string') {\n  text = res.completion;\n} else if (typeof res.text === 'string') {\n  text = res.text;\n}\n\n// Strip markdown fences if present.\ntext = String(text).trim()\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/, '')\n  .replace(/```$/, '')\n  .trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  parsed = {\n    headline: 'Forecast could not be parsed',\n    narrative: text,\n    alert_required: true,\n    alert_severity: 'medium',\n    key_risks: ['Claude output was not valid JSON'],\n    recommended_actions: ['Review the raw model response'],\n    predicted_fill_rate_next_week: null,\n    parse_error: true,\n  };\n}\n\nconst kpi = $('KPI Calculator').all()[0].json;\n\nconst toArr = (v) => Array.isArray(v) ? v : (v ? [String(v)] : []);\nconst keyRisks = toArr(parsed.key_risks);\nconst actions = toArr(parsed.recommended_actions);\n\nreturn [{\n  json: {\n    // KPIs\n    run_date: kpi.run_date,\n    total_roles: kpi.total_roles,\n    filled_roles: kpi.filled_roles,\n    unfilled_count: kpi.unfilled_count,\n    fill_rate: kpi.fill_rate,\n    fill_rate_pct: kpi.fill_rate_pct,\n    revenue_at_risk: kpi.revenue_at_risk,\n    forecast_accuracy_delta: kpi.forecast_accuracy_delta,\n    demand_summary: kpi.demand_summary,\n    supply_summary: kpi.supply_summary,\n    // Claude forecast\n    headline: parsed.headline || '',\n    narrative: parsed.narrative || '',\n    alert_required: parsed.alert_required === true,\n    alert_severity: parsed.alert_severity || 'none',\n    key_risks: keyRisks,\n    key_risks_text: keyRisks.join('\\n'),\n    recommended_actions: actions,\n    recommended_actions_text: actions.join('\\n'),\n    predicted_fill_rate: parsed.predicted_fill_rate_next_week ?? null,\n    parse_error: parsed.parse_error === true,\n    // fixed key so current_state overwrites the same row\n    state_key: 'current',\n  },\n}];\n"
      },
