      "parameters": {
        "jsCode": "\n// ---- Load inputs ------------------------------------------------------\nconst demand = $('Read demand_data').all().map(i => i.json)\n  .filter(r => r && Object.keys(r).length > 0);\nconst supply = $('Read supply_data').all().map(i => i.json)\n  .filter(r => r && Object.keys(r).length > 0);\nconst prevRows = $('Read current_state').all().map(i => i.json)\n  .filter(r => r && Object.keys(r).length > 0);\nconst prev = prevRows.length ? prevRows[prevRows.length - 1] : null;\n\n// ---- Helpers ----------------------------------------------------------\nconst norm = (s) => String(s ?? '').trim().toLowerCase();\nconst toNum = (v) => {\n  if (v === null || v === undefined || v === '') return 0;\n  const n = parseFloat(String(v).replace(/[^0-9.\\-]/g, ''));\n  return isNaN(n) ? 0 : n;\n};\nconst toDate = (v) => {\n  if (!v) return null;\n  const d = new Date(v);\n  return isNaN(d.getTime()) ? null : d;\n};\nconst pick = (obj, keys) => {\n  for (const k of keys) {\n    if (obj[k] !== undefined && obj[k] !== null && obj[k] !== '') return obj[k];\n  }\n  return undefined;\n};\n\n// ---- Role matching ----------------------------------------------------\n// A role is filled when a not-yet-used resource matches on role + region\n// and is available on/before the project start date.\nconst usedResource = new Array(supply.length).fill(false);\nlet filled = 0;\nconst unfilled = [];\nlet revenueAtRisk = 0;\n\nfor (const d of demand) {\n  const roleNeeded = norm(pick(d, ['role_needed', 'role', 'role_required']));\n  const region = norm(pick(d, ['region', 'location']));\n  const startDate = toDate(pick(d, ['start_date', 'project_start_date', 'start']));\n\n  let matchIdx = -1;\n  for (let i = 0; i < supply.length; i++) {\n    if (usedResource[i]) continue;\n    const r = supply[i];\n    const roleMatch = norm(pick(r, ['role', 'role_name'])) === roleNeeded && roleNeeded !== '';\n    const regionMatch = norm(pick(r, ['region', 'location'])) === region;\n    const availFrom = toDate(pick(r, ['available_from', 'availability_date', 'available']));\n    const availMatch = (availFrom && startDate) ? (availFrom.getTime() <= startDate.getTime()) : true;\n    if (roleMatch && regionMatch && availMatch) { matchIdx = i; break; }\n  }\n\n  if (matchIdx >= 0) {\n    usedResource[matchIdx] = true;\n    filled++;\n  } else {\n    const rev = toNum(pick(d, ['revenue', 'revenue_at_risk', 'project_value', 'value', 'contract_value']));\n    revenueAtRisk += rev;\n    unfilled.push({\n      project: pick(d, ['project', 'project_name', 'account', 'client']) || 'Unknown',\n      role_needed: pick(d, ['role_needed', 'role', 'role_required']) || 'Unknown',\n      region: pick(d, ['region', 'location']) || 'Unknown',\n      start_date: pick(d, ['start_date', 'project_start_date', 'start']) || '',\n      revenue_at_risk: rev,\n    });\n  }\n}\n\nconst totalRoles = demand.length;\nconst fillRate = totalRoles > 0 ? filled / totalRoles : 0;\n\n// ---- Forecast Accuracy Delta -----------------------------------------\n// actual fill rate this run vs. last run's PREDICTED fill rate.\nlet forecastAccuracyDelta = null;\nif (prev && prev.predicted_fill_rate !== undefined && prev.predicted_fill_rate !== '') {\n  forecastAccuracyDelta = Number((fillRate - toNum(prev.predicted_fill_rate)).toFixed(4));\n}\n\n// ---- Summary text blocks for Claude ----------------------------------\nconst round1 = (n) => Math.round(n * 1000) / 10; // -> percent, 1 dp\n\nconst demandSummary =\n  'DEMAND SUMMARY\\n' +\n  'Total roles needed: ' + totalRoles + '\\n' +\n  'Roles filled: ' + filled + '\\n' +\n  'Roles unfilled: ' + unfilled.length + '\\n' +\n  (unfilled.length\n    ? 'Unfilled roles:\\n' + unfilled.map((u, i) =>\n        (i + 1) + '. ' + u.role_needed + ' | ' + u.region + ' | starts ' + u.start_date +\n        ' | project ' + u.project + ' | revenue at risk $' + u.revenue_at_risk).join('\\n')\n    : 'All demanded roles are filled.');\n\nconst roleCounts = {};\nfor (const r of supply) {\n  const key = (pick(r, ['role', 'role_name']) || 'Unknown') + ' | ' + (pick(r, ['region', 'location']) || 'Unknown');\n  roleCounts[key] = (roleCounts[key] || 0) + 1;\n}\nconst supplySummary =\n  'SUPPLY SUMMARY\\n' +\n  'Total resources: ' + supply.length + '\\n' +\n  'Resources already allocated this run: ' + usedResource.filter(Boolean).length + '\\n' +\n  'Bench (unallocated): ' + usedResource.filter(x => !x).length + '\\n' +\n  'Resource pool by role | region:\\n' +\n  Object.keys(roleCounts).map(k => '- ' + k + ': ' + roleCounts[k]).join('\\n');\n\n// ---- Claude prompt assembly ------------------------------------------\nconst runDate = $now.toFormat('yyyy-MM-dd');\n\nconst systemPrompt =\n  'You are a resource-planning forecasting analyst. Analyze the weekly demand vs. supply KPIs ' +\n  'and return ONLY a JSON object (no markdown, no prose outside JSON) matching this schema:\\n' +\n  '{\\n' +\n  '  \"headline\": string,\\n' +\n  '  \"narrative\": string,\\n' +\n  '  \"alert_required\": boolean,\\n' +\n  '  \"alert_severity\": \"none\" | \"low\" | \"medium\" | \"high\",\\n' +\n  '  \"key_risks\": string[],\\n' +\n  '  \"recommended_actions\": string[],\\n' +\n  '  \"predicted_fill_rate_next_week\": number\\n' +\n  '}\\n' +\n  'Set alert_required = true when fill rate is below 0.85, revenue at risk is material, ' +\n  'or forecast accuracy is deteriorating. predicted_fill_rate_next_week is a 0-1 decimal.';\n\nconst userPrompt =\n  'Run date: ' + runDate + '\\n\\n' +\n  'KPIs:\\n' +\n  '- Fill Rate: ' + round1(fillRate) + '% (' + filled + '/' + totalRoles + ')\\n' +\n  '- Unfilled Roles: ' + unfilled.length + '\\n' +\n  '- Revenue at Risk: $' + revenueAtRisk + '\\n' +\n  '- Forecast Accuracy Delta: ' + (forecastAccuracyDelta === null ? 'n/a (no prior baseline)' : forecastAccuracyDelta) + '\\n\\n' +\n  demandSummary + '\\n\\n' +\n  supplySummary;\n\nconst claudeBody = {\n  model: 'claude-sonnet-4-5',\n  max_tokens: 2000,\n  system: systemPrompt,\n  messages: [{ role: 'user', content: userPrompt }],\n};\n\nreturn [{\n  json: {\n    run_date: runDate,\n    total_roles: totalRoles,\n    filled_roles: filled,\n    unfilled_count: unfilled.length,\n    fill_rate: Number(fillRate.toFixed(4)),\n    fill_rate_pct: round1(fillRate),\n    revenue_at_risk: revenueAtRisk,\n    forecast_accuracy_delta: forecastAccuracyDelta,\n    unfilled_roles: unfilled,\n    demand_summary: demandSummary,\n    supply_summary: supplySummary,\n    claudeBody,\n  },\n}];\n"
      },
